# .env.example
# Rename this file to .env and fill in your own passwords!

# Database Configuration
DATABASE_PASSWORD=create_a_secure_password_here
DATABASE_URL=postgresql://postgres:create_a_secure_password_here@db:5432/stock_db

# Email/Auth Configuration
SECRET_KEY=generate_a_random_secret_string_here
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password